# Alpha-Omega on Clouding.io (JSON persistence — no Supabase required)
STORAGE_MODE=json
AO_DATA_ROOT=/var/lib/alpha-omega

# Copy secrets from your local .env (do NOT commit real values):
# GOOGLE_API_KEY=
# TELEGRAM_TOKEN=
# TELEGRAM_PERSONAL_CHAT_ID=
# OWNER_PASSWORD=
# FINNHUB_API_KEY=

# Leave Supabase blank on Clouding (optional — ignored when STORAGE_MODE=json)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
